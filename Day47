

class Solution {
public:
    int lengthOfLastWord(string s) {
        int len = 0;
        int i = s.length() - 1;

        // End ke spaces skip karo
        while (i >= 0 && s[i] == ' ') {
            i--;
        }

        // Last word count karo
        while (i >= 0 && s[i] != ' ') {
            len++;
            i--;
        }

        return len;
    }
};
