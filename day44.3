

#include <iostream>
using namespace std;

int reverseNum(int n, int rev = 0)
{
    // Base condition
    if(n == 0)
        return rev;

    // Recursive call
    return reverseNum(n / 10, rev * 10 + n % 10);
}

int main()
{
    int n;

    cout << "Enter a number: ";
    cin >> n;

    cout << "Reversed Number = " << reverseNum(n);

    return 0;
}
