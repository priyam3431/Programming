

#include <iostream>
using namespace std;

// Recursive function for fibonacci
int fibonacci(int n)
{
    // Base conditions
    if(n == 0)
        return 0;

    if(n == 1)
        return 1;

    // Recursive call
    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main()
{
    int n;

    cout << "Enter number of terms: ";
    cin >> n;

    for(int i = 0; i < n; i++)
    {
        cout << fibonacci(i) << " ";
    }

    return 0;
}
