


#include <iostream>
using namespace std;

// Recursive function for power
int power(int base, int exp)
{
    // Base condition
    if(exp == 0)
        return 1;

    // Recursive call
    return base * power(base, exp - 1);
}

int main()
{
    int base, exp;

    cout << "Enter base and exponent: ";
    cin >> base >> exp;

    cout << "Result = " << power(base, exp);

    return 0;
}
