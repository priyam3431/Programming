//to find the second largest in the array....

#include <iostream>
#include <vector>
#include <climits>
using namespace std;

int secondLargest(vector<int> &arr){
    
    if(arr.size() < 2){
        return -1; // second largest possible nahi
    }

    int largest = INT_MIN;
    int secondLargest = INT_MIN;

    for(int i = 0; i < arr.size(); i++){
        
        if(arr[i] > largest){
            secondLargest = largest;
            largest = arr[i];
        }
        else if(arr[i] > secondLargest && arr[i] != largest){
            secondLargest = arr[i];
        }
    }

    if(secondLargest == INT_MIN){
        return -1; // matlab second largest exist nahi karta
    }

    return secondLargest;
}

int main()
{
    vector<int> arr = {1,2,3,4,5};

    int result = secondLargest(arr);

    if(result == -1){
        cout << "Second largest element does not exist";
    } else {
        cout << "Second largest element is: " << result;
    }

    return 0;
}
