

#include <iostream>
using namespace std;

int main() {
    int arr[] = {10, 45, 67, 23, 89};
    int n = 5;

    int largest = arr[0];

    for(int i = 1; i < n; i++) {
        if(arr[i] > largest) {
            largest = arr[i];
        }
    }

    cout << "Largest element = " << largest;

    return 0;
}
