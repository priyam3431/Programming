

#include <iostream>
#include <string>
using namespace std;

int main() {
    string str;
    string rev = "";

    cout << "Enter a string: ";
    cin >> str;

    // Reverse the string
    for (int i = str.length() - 1; i >= 0; i--) {
        rev = rev + str[i];
    }

    // Check palindrome
    if (str == rev) {
        cout << "Palindrome String";
    } else {
        cout << "Not Palindrome";
    }

    return 0;
}
