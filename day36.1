


#include <iostream>
using namespace std;

int main() {

    int arr[2][2];
    int sum = 0;

    // Input
    cout << "Enter elements:\n";

    for(int i = 0; i < 2; i++) {
        for(int j = 0; j < 2; j++) {
            cin >> arr[i][j];
        }
    }

    // Sum calculate
    for(int i = 0; i < 2; i++) {
        for(int j = 0; j < 2; j++) {
            sum = sum + arr[i][j];
        }
    }

    cout << "Sum = " << sum;

    return 0;
}
