

#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter number of terms: ";
    cin >> n;

    long long a = 0, b = 1;
    cout << "Fibonacci Series: ";

    for (int i = 0; i < n; i++) {
        cout << a;
        if (i < n - 1) cout << ", ";
        long long temp = a + b;
        a = b;
        b = temp;
    }

    cout << endl;
    return 0;
}
