#include <iostream>
#include <string>
#include <algorithm>
using namespace std;

bool isPalindrome(string s) {
    string rev = s;
    reverse(rev.begin(), rev.end());
    return s == rev;
}

int main() {
    string str;
    cout << "Enter a string: ";
    cin >> str;
    
    if (isPalindrome(str)) {
        cout << str << " is a Palindrome!" << endl;
    } else {
        cout << str << " is NOT a Palindrome!" << endl;
    }
    
    return 0;
}
