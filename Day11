//find the factorial... 

#include <stdio.h>

int main() {
    int n, i;
    long long factorial = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    // factorial of negative number doesn't exist
    if (n < 0) {
        printf("Factorial is not defined for negative numbers.");
    } else {
        for (i = 1; i <= n; i++) {
            factorial = factorial * i;
        }
        printf("Factorial of %d is %lld", n, factorial);
    }

    return 0;
}
