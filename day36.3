


#include <iostream>
using namespace std;

int main() {

    int arr[2][3];

    // Input
    cout << "Enter elements:\n";

    for(int i = 0; i < 2; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> arr[i][j];
        }
    }

    // Row wise sum
    for(int i = 0; i < 2; i++) {

        int sum = 0;

        for(int j = 0; j < 3; j++) {
            sum = sum + arr[i][j];
        }

        cout << "Sum of Row " << i << " = " << sum << endl;
    }

    return 0;
}
