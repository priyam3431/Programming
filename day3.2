//scannning multiple values..

#include <stdio.h>

int main()
{
 int roll_no;
 char grade;
 float per;
 printf("Enter roll_no\n");
 scanf("%d",&roll_no);
 printf("Enter grade\n");
 scanf(" %c",&grade);
 printf("Enter per\n");
 scanf("%f",&per);
 printf("The roll_no is %d\n",roll_no);
 printf("Grade is %c\n",grade);
 printf("Percentage is %f",per);
    return 0;
}
