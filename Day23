using namespace std;

// Abstract class (pure abstraction)
class Shape {
public:
    // Pure virtual functions - only interface exposed
    virtual double area() = 0;
    virtual double perimeter() = 0;
    virtual void display() = 0;
    virtual ~Shape() {}
};

// Concrete class - Circle
