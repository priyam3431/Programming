//Basic arithmatic opreators

#include <stdio.h>

int main()
{
   int a=5,b=3;
   int sum,sub,mul,divv,mod;
   sum=a+b;
   sub=a-b;
   mul=a*b;
   divv=a/b;
   mod=a%b;
   printf("sum of a and b is %d\n",sum);
   printf("sub of a and b is %d\n",sub);
   printf("mul of a and b is %d\n",mul);
    printf("divv of a and b is %d\n",divv);
     printf("mod of a and b is %d",mod);
   

    return 0;
}
